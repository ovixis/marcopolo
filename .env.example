# Copy to .env and fill in what you have. Everything is optional —
# the app runs in demo mode with locally generated sample data when
# provider keys are missing.

# --- Duffel (flight search) --------------------------------------------------
# Free test-mode keys: https://app.duffel.com (Developers → Access tokens).
# Test keys start with "duffel_test_" and return sandbox offers; live keys
# return real content. (Amadeus self-service was decommissioned 2026-07-17.)
DUFFEL_API_KEY=

# --- LiteAPI / Nuitee (hotel search) ------------------------------------------
# Keys at https://liteapi.travel — searches are free, only bookings are billed.
# prod_… keys return live rates; sand_… keys are sandbox.
LITEAPI_API_KEY=

# --- Supabase (auth, database, photo storage) --------------------------------
# Create a free project at https://supabase.com, then apply the schema:
#   supabase link --project-ref <ref> && supabase db push
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (AI journal, roadmap weeks 11-12) -----------------------------
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Booking.com / Viator (roadmap weeks 5-8) --------------------------------
BOOKING_AFFILIATE_ID=
VIATOR_API_KEY=

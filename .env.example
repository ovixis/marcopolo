# Copy to .env and fill in what you have. Everything is optional —
# the app runs in demo mode with locally generated sample data when
# provider keys are missing.

# --- Amadeus (flight search) -------------------------------------------------
# Free self-service keys: https://developers.amadeus.com
# AMADEUS_ENV=test uses the sandbox (default); set to "production" for live data.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# --- Supabase (auth, database, photo storage) --------------------------------
# Create a free project at https://supabase.com, then apply the schema:
#   supabase link --project-ref <ref> && supabase db push
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (AI journal, roadmap weeks 11-12) -----------------------------
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Booking.com / Viator (roadmap weeks 5-8) --------------------------------
BOOKING_AFFILIATE_ID=
VIATOR_API_KEY=
